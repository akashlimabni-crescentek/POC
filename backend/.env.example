# Copy to backend/.env and fill in values from Supabase Dashboard → Settings → API
# No leading/trailing whitespace on any line.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_B64=
# Optional comma-separated series for cold sync (e.g. KXWC2026,KXHIGHNY)
KALSHI_SERIES_TICKERS=
# Alternative to B64: paste PEM directly (use \n for newlines)
# KALSHI_PRIVATE_KEY_PEM=
