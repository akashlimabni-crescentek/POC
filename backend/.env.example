# Copy to backend/.env and fill in values from Supabase Dashboard → Settings → API
# No leading/trailing whitespace on any line.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional comma-separated Polymarket event slugs or numeric Gamma event ids.
# When set, only these events are synced (e.g. kraken-ipo-in-2025,16183).
# POLYMARKET_EVENT_TICKERS=kraken-ipo-in-2025

KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_B64=
# Optional comma-separated series for cold sync.
# Use "auto" to discover all FIFA Men's World Cup series (same as legacy worker3).
# Or list explicit tickers, e.g. KXHIGHNY,KXWCGAME
KALSHI_SERIES_TICKERS=auto
# Optional comma-separated event_tickers — only sync/show these Kalshi events
KALSHI_EVENT_TICKERS=KXWC1H-26JUL02ESPAUT
# Alternative to B64: paste PEM directly (use \n for newlines)
# KALSHI_PRIVATE_KEY_PEM=

# Set to 1 to inject wide random static prices for candle/chart testing only
# KALSHI_STATIC_TEST_PRICES=1
