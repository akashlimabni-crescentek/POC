# This monorepo uses split env files — do not put secrets here.
#
# Backend workers (service role + Kalshi):
#   cp backend/.env.example backend/.env
#
# Frontend (anon key only):
#   cp frontend/.env.local.example frontend/.env.local
#
# Validate before starting:
#   npm run validate:env
#
# SUPABASE_URL must be https://<project-ref>.supabase.co (NOT .../rest/v1/).
# No leading/trailing whitespace on any env line.
